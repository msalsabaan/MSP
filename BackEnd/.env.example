# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:4200

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=msp
DB_PASSWORD=msp_password
DB_NAME=msp_db
# In dev, TypeORM auto-creates tables. Set false in prod and use migrations.
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Seed admin (created by `npm run seed`)
SEED_ADMIN_EMAIL=admin@msp.sa
SEED_ADMIN_PASSWORD=Admin@12345

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
